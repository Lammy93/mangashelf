# Port mapping
HOST_PORT=8035

# Volume paths (use absolute paths or relative to docker-compose.yml)
MANGA_DIR=./manga
DATA_DIR=./data

# Timezone
TZ=Australia/Brisbane

# Security - generate a long random string
SECRET_KEY=change-this-to-a-long-random-string

# Resource limits
CPU_LIMIT=2.0
MEMORY_LIMIT=1G
CPU_RESERVATION=0.5
MEMORY_RESERVATION=256M
